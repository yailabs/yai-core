{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.net.stream.envelope.v1",
  "title": "YAI NET Stream Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stream_id",
    "invocation_id",
    "trace_id",
    "sequence",
    "event_kind",
    "stream_state",
    "payload_kind",
    "origin_node_id",
    "target_node_id",
    "timestamp_unix_ms",
    "payload"
  ],
  "properties": {
    "schema_version": { "const": "net.stream.envelope.v1" },
    "stream_id": { "type": "string" },
    "invocation_id": { "type": "string" },
    "trace_id": { "type": "string" },
    "sequence": { "type": "integer", "minimum": 0 },
    "event_kind": {
      "enum": ["request", "response", "chunk", "metric", "receipt", "error", "complete"]
    },
    "stream_state": {
      "enum": ["created", "open", "half_closed", "completed", "failed", "cancelled"]
    },
    "payload_kind": {
      "enum": ["none", "bytes", "text", "json", "metric", "receipt", "error"]
    },
    "origin_node_id": { "type": "string" },
    "target_node_id": { "type": "string" },
    "timestamp_unix_ms": { "type": "integer", "minimum": 0 },
    "payload": {
      "type": ["object", "string", "null"]
    }
  }
}
