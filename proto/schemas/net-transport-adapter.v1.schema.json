{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.net.transport.adapter.v1",
  "title": "YAI NET Transport Adapter Descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "transport_adapter_id",
    "endpoint_id",
    "transport_label",
    "transport_kind",
    "transport_scope",
    "transport_state",
    "transport_security",
    "stream_profile",
    "metadata",
    "declared_at_unix_ms"
  ],
  "properties": {
    "schema_version": { "const": "net.transport.adapter.v1" },
    "transport_adapter_id": { "type": "string" },
    "endpoint_id": { "type": "string" },
    "transport_label": { "type": "string" },
    "transport_kind": {
      "enum": ["localhost_http", "local_ipc", "lan_http", "remote_http", "future"]
    },
    "transport_scope": {
      "enum": ["process", "machine", "lan", "remote", "external"]
    },
    "transport_state": {
      "enum": ["unknown", "declared", "available", "degraded", "unavailable", "retired"]
    },
    "transport_security": {
      "enum": ["unknown", "local_only", "trusted_local", "declared_remote", "external_untrusted"]
    },
    "stream_profile": { "type": "string" },
    "metadata": { "type": "object" },
    "declared_at_unix_ms": { "type": "integer", "minimum": 0 }
  }
}
