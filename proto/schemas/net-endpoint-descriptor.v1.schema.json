{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.net.endpoint.descriptor.v1",
  "title": "YAI NET Endpoint Descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "endpoint_id",
    "node_id",
    "endpoint_label",
    "endpoint_kind",
    "endpoint_scope",
    "endpoint_state",
    "endpoint_security",
    "address_ref",
    "metadata",
    "declared_at_unix_ms",
    "capability_refs"
  ],
  "properties": {
    "schema_version": { "const": "net.endpoint.descriptor.v1" },
    "endpoint_id": { "type": "string" },
    "node_id": { "type": "string" },
    "endpoint_label": { "type": "string" },
    "endpoint_kind": {
      "enum": ["local_process", "localhost_http", "local_ipc", "lan_http", "remote_http", "future_transport"]
    },
    "endpoint_scope": {
      "enum": ["process", "machine", "lan", "remote", "external"]
    },
    "endpoint_state": {
      "enum": ["unknown", "declared", "available", "degraded", "unavailable", "retired"]
    },
    "endpoint_security": {
      "enum": ["unknown", "local_only", "trusted_local", "declared_remote", "external_untrusted"]
    },
    "address_ref": { "type": "string" },
    "metadata": { "type": "object" },
    "declared_at_unix_ms": { "type": "integer", "minimum": 0 },
    "capability_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
