{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.net.lifecycle.report.v1",
  "title": "YAI NET Lifecycle Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lifecycle_report_id",
    "subject_id",
    "subject_kind",
    "lifecycle_state",
    "observed_by_node_id",
    "reason",
    "metadata",
    "observed_at_unix_ms"
  ],
  "properties": {
    "schema_version": { "const": "net.lifecycle.report.v1" },
    "lifecycle_report_id": { "type": "string" },
    "subject_id": { "type": "string" },
    "subject_kind": {
      "enum": ["node", "endpoint", "capability", "service", "external"]
    },
    "lifecycle_state": {
      "enum": ["unknown", "declared", "preparing", "starting", "running", "stopping", "stopped", "failed", "retired"]
    },
    "observed_by_node_id": { "type": "string" },
    "reason": { "type": "string" },
    "metadata": { "type": "object" },
    "observed_at_unix_ms": { "type": "integer", "minimum": 0 }
  }
}
