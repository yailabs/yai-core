{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.net.capability.advertisement.v1",
  "title": "YAI NET Capability Advertisement v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "capability_id",
    "node_id",
    "capability_label",
    "capability_kind",
    "capability_family",
    "capability_scope",
    "capability_state",
    "constraints",
    "metadata",
    "advertised_at_unix_ms"
  ],
  "properties": {
    "schema_version": { "const": "net.capability.advertisement.v1" },
    "capability_id": { "type": "string" },
    "node_id": { "type": "string" },
    "capability_label": { "type": "string" },
    "capability_kind": {
      "enum": ["neural_llm_decode", "neural_embedding_encode", "metrics_stream", "receipt_emit", "generic_external"]
    },
    "capability_family": {
      "enum": ["neural", "metrics", "receipt", "generic"]
    },
    "capability_scope": {
      "enum": ["process", "node", "service", "external"]
    },
    "capability_state": {
      "enum": ["unknown", "declared", "available", "degraded", "unavailable", "retired"]
    },
    "constraints": { "type": "object" },
    "metadata": { "type": "object" },
    "advertised_at_unix_ms": { "type": "integer", "minimum": 0 }
  }
}
