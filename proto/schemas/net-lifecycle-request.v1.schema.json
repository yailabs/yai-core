{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.net.lifecycle.request.v1",
  "title": "YAI NET Lifecycle Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lifecycle_request_id",
    "subject_id",
    "subject_kind",
    "requested_action",
    "requested_by_node_id",
    "reason",
    "metadata",
    "requested_at_unix_ms"
  ],
  "properties": {
    "schema_version": { "const": "net.lifecycle.request.v1" },
    "lifecycle_request_id": { "type": "string" },
    "subject_id": { "type": "string" },
    "subject_kind": {
      "enum": ["node", "endpoint", "capability", "service", "external"]
    },
    "requested_action": {
      "enum": ["declare", "prepare", "start", "stop", "restart", "status", "retire"]
    },
    "requested_by_node_id": { "type": "string" },
    "reason": { "type": "string" },
    "metadata": { "type": "object" },
    "requested_at_unix_ms": { "type": "integer", "minimum": 0 }
  }
}
