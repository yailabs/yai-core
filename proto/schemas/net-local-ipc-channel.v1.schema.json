{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.net.local_ipc.channel.v1",
  "title": "YAI NET Local IPC Channel Descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ipc_channel_id",
    "transport_adapter_id",
    "endpoint_id",
    "channel_label",
    "channel_kind",
    "channel_scope",
    "channel_state",
    "channel_security",
    "channel_ref",
    "metadata",
    "declared_at_unix_ms"
  ],
  "properties": {
    "schema_version": { "const": "net.local_ipc.channel.v1" },
    "ipc_channel_id": { "type": "string" },
    "transport_adapter_id": { "type": "string" },
    "endpoint_id": { "type": "string" },
    "channel_label": { "type": "string" },
    "channel_kind": {
      "enum": ["abstract_local", "unix_socket_future", "named_pipe_future", "platform_ipc_future", "memory_channel_future"]
    },
    "channel_scope": {
      "enum": ["process", "machine", "session", "future"]
    },
    "channel_state": {
      "enum": ["unknown", "declared", "available", "degraded", "unavailable", "retired"]
    },
    "channel_security": {
      "enum": ["unknown", "local_only", "same_user_future", "declared_local", "untrusted"]
    },
    "channel_ref": { "type": "string" },
    "metadata": { "type": "object" },
    "declared_at_unix_ms": { "type": "integer", "minimum": 0 }
  }
}
