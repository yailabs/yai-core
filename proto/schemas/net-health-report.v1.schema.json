{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.net.health.report.v1",
  "title": "YAI NET Health Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "health_report_id",
    "subject_id",
    "subject_kind",
    "check_kind",
    "health_state",
    "observed_by_node_id",
    "reason",
    "metadata",
    "observed_at_unix_ms"
  ],
  "properties": {
    "schema_version": { "const": "net.health.report.v1" },
    "health_report_id": { "type": "string" },
    "subject_id": { "type": "string" },
    "subject_kind": {
      "enum": ["node", "endpoint", "capability", "transport", "external"]
    },
    "check_kind": {
      "enum": ["health", "liveness", "readiness", "capability_readiness", "endpoint_reachability"]
    },
    "health_state": {
      "enum": ["unknown", "alive", "ready", "degraded", "unavailable", "failed"]
    },
    "observed_by_node_id": { "type": "string" },
    "reason": { "type": "string" },
    "metadata": { "type": "object" },
    "observed_at_unix_ms": { "type": "integer", "minimum": 0 }
  }
}
