{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.test-definition.v0",
  "title": "YAI Test Definition v0",
  "type": "object",
  "required": ["id", "title", "status", "version", "date", "lab"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*\\.T[0-9]{3}$"
    },
    "title": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "frozen", "archived", "superseded"]
    },
    "version": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "minLength": 1 },
    "lab": { "type": "string", "minLength": 1 },
    "latest_run": {
      "type": ["string", "null"]
    },
    "report": { "type": ["string", "null"] },
    "notebook": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
