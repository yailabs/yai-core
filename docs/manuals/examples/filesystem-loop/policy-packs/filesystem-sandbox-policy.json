{
  "schema": "yai.manual.policy_pack.v0",
  "policy_ref": "policy:manual-filesystem-sandbox-v0",
  "case_ref": "case:new12-filesystem",
  "subject_ref": "subject:filesystem-sandbox",
  "source_ref": "manual-filesystem-loop-validation",
  "summary": "Filesystem sandbox policy for manual daemon loop validation.",
  "rules": [
    {
      "rule_ref": "rule:fs-read-observe-inside-sandbox",
      "effect": "allow_observed",
      "operation": "fs.read",
      "scope": "sandbox_only",
      "failure_mode": "deny_without_receipt_path",
      "evidence_required": ["filesystem_receipt"]
    },
    {
      "rule_ref": "rule:fs-mutative-write-requires-review",
      "effect": "require_review",
      "operation": "fs.write",
      "scope": "mutative",
      "failure_mode": "require_review",
      "evidence_required": ["decision", "filesystem_receipt"]
    },
    {
      "rule_ref": "rule:fs-write-allow-only-inside-sandbox",
      "effect": "allow_with_constraints",
      "operation": "fs.write",
      "scope": "sandbox_only",
      "constraints": ["sandbox_only"],
      "failure_mode": "deny_without_receipt_path",
      "evidence_required": ["decision", "filesystem_receipt"]
    }
  ]
}

