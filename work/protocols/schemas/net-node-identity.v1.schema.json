{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.net.node.identity.v1",
  "title": "YAI NET Node Identity v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "node_id",
    "node_label",
    "node_kind",
    "node_scope",
    "node_state",
    "identity_source",
    "safe_metadata",
    "observed_at_unix_ms",
    "endpoint_refs",
    "capability_refs"
  ],
  "properties": {
    "schema_version": { "const": "net.node.identity.v1" },
    "node_id": { "type": "string" },
    "node_label": { "type": "string" },
    "node_kind": {
      "enum": ["local", "localhost_service", "lan", "remote", "external"]
    },
    "node_scope": {
      "enum": ["process", "machine", "lan", "remote", "external"]
    },
    "node_state": {
      "enum": ["unknown", "declared", "observed", "healthy", "degraded", "unavailable", "retired"]
    },
    "identity_source": { "type": "string" },
    "safe_metadata": { "type": "object" },
    "observed_at_unix_ms": { "type": "integer", "minimum": 0 },
    "endpoint_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "capability_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
